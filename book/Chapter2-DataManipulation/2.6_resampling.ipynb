    "plt.scatter(in_square[:,0], in_square[:,1], marker='x', c='black')\n",
    "plt.scatter(in_circle[:,0], in_circle[:,1], marker='o', c='red')\n",
    "plt.xlabel('X coordinate')\n",
    "plt.ylabel('Y coordinate')\n",
